{{ 'product-extra-info.css' | asset_url | stylesheet_tag }}
{% schema %}
{
  "name": "Informações Extras",
  "settings": [
    {
      "type": "text",
      "id": "titulo",
      "label": "Título da seção",
      "default": "Informações do Produto"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    {
      "name": "Informações Extras"
    }
  ]
}
{% endschema %}

{% if product.metafields.custom.material != blank
  or product.metafields.custom.instrucoes_cuidado != blank
  or product.metafields.custom.video_url != blank
%}
  <div class="product-extra-info">
    <h2 class="product-extra-info__titulo">{{ section.settings.titulo }}</h2>
    {% if product.metafields.custom.material %}
      <div class="product-extra-info__item">
        <strong>Material:</strong>
        <span>{{ product.metafields.custom.material.value }}</span>
      </div>
    {% endif %}
    {% if product.metafields.custom.instrucoes_cuidado != blank %}
      <details
        class="collapsible"
        {% if section.settings.open %}
          open
        {% endif %}
      >
        <summary>Instruções de cuidado</summary>
        <div class="collapsible__content">
          <div class="collapsible__content__inner">
            {{ product.metafields.custom.instrucoes_cuidado | metafield_tag }}
          </div>
        </div>
      </details>
    {% endif %}
    {% if product.metafields.custom.video_url != blank %}
      {%- assign video_url = product.metafields.custom.video_url.value -%}
      {%- if video_url contains 'youtube.com/watch?v=' -%}
        {%- assign video_url = video_url | replace: 'watch?v=', 'embed/' -%}
      {%- elsif video_url contains 'youtu.be/' -%}
        {%- assign video_url = video_url | replace: 'youtu.be/', 'youtube.com/embed/' -%}
      {%- elsif video_url contains 'youtube.com/shorts/' -%}
        {%- assign video_url = video_url | replace: 'youtube.com/shorts/', 'youtube.com/embed/' -%}
      {%- endif -%}

      <iframe
        src="{{ video_url }}"
        title="{{ product.title }}"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    {% endif %}
  </div>
{% endif %}
