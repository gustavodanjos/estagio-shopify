<section class="lista-caracteristicas">
  <div class="lista-caracteristicas__container">
    {% if section.settings.titulo != blank %}
      <h2 class="lista-caracteristicas__titulo">{{ section.settings.titulo }}</h2>
    {% endif %}

    <div class="lista-caracteristicas__grid">
      {% for block in section.blocks %}
        <div class="lista-caracteristicas__item" {{ block.shopify_attributes }}>
          {% if block.settings.icone %}
            <img
              src="{{ block.settings.icone | image_url: width: 440 }}"
              alt="{{ block.settings.titulo | escape }}"
              width="80"
              height="80"
              loading="lazy"
              class="lista-caracteristicas__icone"
            >
          {% endif %}
          <h3 class="lista-caracteristicas__item-titulo">{{ block.settings.titulo }}</h3>
          <p class="lista-caracteristicas__item-descricao">{{ block.settings.descricao }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .lista-caracteristicas__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .lista-caracteristicas__titulo {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 2.5rem;
  }

  .lista-caracteristicas__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .lista-caracteristicas__item {
    text-align: center;
  }

  .lista-caracteristicas__icone {
    margin-bottom: 1rem;
    object-fit: contain;
    width: 120px;
    height: 120px;
  }

  .lista-caracteristicas__item-titulo {
    font-size: 1.15rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .lista-caracteristicas__item-descricao {
    font-size: 0.95rem;
    color: #555;
  }

  @media screen and (min-width: 750px) {
    .lista-caracteristicas__grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Lista de Características",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "titulo",
      "label": "Título da seção",
      "default": "Por que escolher a gente"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icone",
          "label": "Ícone"
        },
        {
          "type": "text",
          "id": "titulo",
          "label": "Título",
          "default": "Característica"
        },
        {
          "type": "textarea",
          "id": "descricao",
          "label": "Descrição",
          "default": "Descreva essa característica."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lista de Características",
      "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }]
    }
  ]
}
{% endschema %}
