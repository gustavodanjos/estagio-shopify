{% schema %}
{
  "name": "Depoimentos",
  "class": "section",
  "blocks": [
    {
      "type": "depoimento",
      "name": "Depoimento",
      "settings": [
        {
          "type": "metaobject",
          "id": "depoimento",
          "label": "Depoimento em destaque",
          "metaobject_type": "depoimento"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Depoimentos"
    }
  ]
}
{% endschema %}
{{ 'adepoimentos.css' | asset_url | stylesheet_tag }}
<script src="{{ 'adepoimentos.js' | asset_url }}" defer></script>

<depoimentos-carousel id="depoimentos">
  <button class="carousel__prev">‹</button>

  <div class="depoimentos-wrapper">
    {% for block in section.blocks %}
      {% assign depoimento = block.settings.depoimento %}
      {% if depoimento %}
        <div class="depoimento" {{ block.shopify_attributes }}>
          {% if depoimento.foto_do_cliente.value %}
            <img
              src="{{ depoimento.foto_do_cliente.value | image_url: width: 80 }}"
              alt="{{ depoimento.nome_do_cliente.value }}"
              width="80"
              height="80"
            >
          {% endif %}
          <p>"{{ depoimento.texto_do_depoimento.value }}"</p>
          <span>— {{ depoimento.nome_do_cliente.value }}</span>
          <span>{{ depoimento.avaliacao.value }} ⭐</span>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <button class="carousel__next">›</button>
</depoimentos-carousel>
